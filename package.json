{
  "name": "@respec-gtc/converters",
  "version": "0.1.0",
  "description": "Respec skill converters for multi-tool export",
  "scripts": {
    "lint": "node scripts/lint-skills.js",
    "lint:fix": "node scripts/lint-skills.js --fix",
    "build:index": "node scripts/build-index.js",
    "search": "node scripts/search.js",
    "health": "node scripts/health-check.js",
    "postinstall": "npm run build:index",
    "convert:cursor": "node converters/cursor.js --all",
    "convert:aider": "node converters/aider.js",
    "convert:windsurf": "node converters/windsurf.js",
    "convert:copilot": "node converters/copilot.js --all",
    "convert:all": "npm run convert:cursor && npm run convert:aider && npm run convert:windsurf && npm run convert:copilot"
  },
  "dependencies": {
    "yaml": "^2.3.4"
  }
}
